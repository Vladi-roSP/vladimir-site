---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    date: string;
    description: string;
    tags?: string[];
    image?: string;
  };
}

const { frontmatter } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const dateStr = new Date(frontmatter.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${frontmatter.title} — S. Vladimir Rodríguez`} description={frontmatter.description}>
  <article class="blog-post-page">
    <div class="container">
      <a href={`${base}/blog`} class="back-link">&larr; Back to Blog</a>

      <header class="post-header fade-in">
        <h1>{frontmatter.title}</h1>
        <div class="post-meta">
          <time datetime={frontmatter.date}>{dateStr}</time>
          {frontmatter.tags && (
            <div class="post-tags">
              {frontmatter.tags.map((tag: string) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </header>

      {frontmatter.image && (
        <img src={frontmatter.image} alt={frontmatter.title} class="post-hero-image fade-in" />
      )}

      <div class="post-content fade-in">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post-page {
    padding: 8rem 0 4rem;
    min-height: 100vh;
  }

  .back-link {
    display: inline-block;
    color: var(--accent);
    text-decoration: none;
    margin-bottom: 2rem;
    font-size: 0.9rem;
    transition: opacity 0.3s;
  }

  .back-link:hover {
    opacity: 0.7;
  }

  .post-header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .post-hero-image {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 12px;
    margin-bottom: 2rem;
  }

  .post-content {
    max-width: 720px;
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-secondary);
  }

  .post-content :global(h2) {
    color: var(--text-primary);
    font-size: 1.6rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .post-content :global(h3) {
    color: var(--text-primary);
    font-size: 1.3rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .post-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .post-content :global(a) {
    color: var(--accent);
    text-decoration: underline;
  }

  .post-content :global(code) {
    background: var(--surface);
    padding: 0.2em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .post-content :global(pre) {
    background: var(--surface);
    padding: 1.5rem;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1.5rem;
    margin: 1.5rem 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  .post-content :global(ul), .post-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.5rem;
  }
</style>
