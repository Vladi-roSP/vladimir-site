---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Experience — S. Vladimir Rodríguez">
  <section class="page-hero">
    <div class="container">
      <span class="section-label fade-in">EXPERIENCE</span>
      <h1 class="fade-in">Experience</h1>
      <p class="page-desc fade-in">
        A blend of academic research, technology consulting, and civic engagement — driven by
        the goal of creating meaningful impact through computation and collaboration.
      </p>
    </div>
  </section>

  <!-- Professional Experience -->
  <section class="section">
    <div class="container">
      <h2 class="fade-in">Professional Experience</h2>
      <div class="timeline">
        <div class="timeline-item fade-in">
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <div class="timeline-header">
              <h3>EXIMICS México</h3>
              <span class="timeline-date">2025 – Present</span>
            </div>
            <p class="timeline-role">Technology Consultant — Process Automation & Implementation Lead</p>
            <ul class="timeline-details">
              <li>Leading the design and deployment of process automation strategies and emerging technology integration.</li>
              <li>Directing cross-functional initiatives to streamline operational workflows and drive digital transformation.</li>
            </ul>
          </div>
        </div>

        <div class="timeline-item fade-in">
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <div class="timeline-header">
              <h3>Universidad Iberoamericana (IBERO)</h3>
              <span class="timeline-date">2024</span>
            </div>
            <p class="timeline-role">Teaching & IT Assistant — Department of Telecommunications</p>
            <ul class="timeline-details">
              <li>Assisting Prof. Guillermo Abascal with the modernization and upgrade of departmental computing systems.</li>
              <li>Provided academic tutoring to undergraduate students in object-oriented programming. <span class="completed-tag">Completed</span></li>
            </ul>
          </div>
        </div>

        <div class="timeline-item fade-in">
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <div class="timeline-header">
              <h3>Geekplace México</h3>
              <span class="timeline-date">2025</span>
            </div>
            <p class="timeline-role">Market Research Consultant</p>
            <ul class="timeline-details">
              <li>Conducted market intelligence analysis and delivered data-driven strategic recommendations to support business development and product positioning.</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Leadership & Civic Engagement -->
  <section class="section leadership-section">
    <div class="container">
      <h2 class="fade-in">Leadership & Civic Engagement</h2>
      <div class="leadership-grid">
        <div class="leadership-card fade-in">
          <span class="leadership-date">April 2024</span>
          <h3>#IberoDialoga: Encuentros por la Democracia</h3>
          <p class="leadership-role">Student Moderator — Presidential Candidate Dialogue</p>
          <p class="leadership-desc">
            Selected to moderate the institutional dialogue between presidential candidate Xóchitl Gálvez Ruiz
            and the IBERO university community as part of the 2024 Mexican general election cycle. The event
            convened over 600 attendees and was broadcast to an additional 2,000 students across campus.
          </p>
        </div>
        <div class="leadership-card fade-in">
          <span class="leadership-date">2024</span>
          <h3>N+ (TelevisaUnivision)</h3>
          <p class="leadership-role">Television Commentator — 2024 Mexican Presidential Election</p>
          <p class="leadership-desc">
            Invited as a guest commentator on national public television to discuss the 2024 Mexican presidential
            election from a university student perspective, offering analysis on youth civic engagement and electoral issues.
          </p>
        </div>
        <div class="leadership-card fade-in">
          <span class="leadership-date">2024</span>
          <h3>Coparmex–IBERO University Chapter</h3>
          <p class="leadership-role">Member — University Entrepreneurship & Private Sector Liaison</p>
          <p class="leadership-desc">
            Participated in the Coparmex–IBERO university chapter, a partnership between Universidad Iberoamericana
            and Coparmex CDMX aimed at fostering student engagement with the private sector, promoting
            entrepreneurship, innovation, and professional development.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Student Publications -->
  <section class="section">
    <div class="container">
      <h2 class="fade-in">Student Publications</h2>
      <div class="publications-list">
        <div class="publication-item fade-in">
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <div class="timeline-header">
              <h3>La Pregonera</h3>
              <span class="timeline-date">2024</span>
            </div>
            <p class="timeline-role">Editorial Director — Student Review Magazine</p>
            <ul class="timeline-details">
              <li>Served as Editorial Director of La Pregonera, the largest student magazine at IBERO, dedicated to critical analysis of social issues including human rights, politics, gender, and public policy.</li>
            </ul>
          </div>
        </div>
        <div class="publication-item fade-in">
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <div class="timeline-header">
              <h3>El Gato en la Caja</h3>
              <span class="timeline-date">2024</span>
            </div>
            <p class="timeline-role">Contributing Writer — Physics & Science Outreach Magazine</p>
            <ul class="timeline-details">
              <li>Contributed to El Gato en la Caja, a science outreach magazine managed by the Department of Physics and Mathematics (FISMAT) at IBERO, focused on making scientific topics accessible to the general public.</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Education -->
  <section class="section">
    <div class="container">
      <h2 class="fade-in">Education</h2>
      <div class="education-grid">
        <div class="edu-item fade-in">
          <h3>Universidad Iberoamericana Ciudad de México</h3>
          <p class="edu-degree">B.Sc. in Physics</p>
          <span class="edu-years">2022 – 2026 (expected)</span>
          <p class="edu-note">Awarded the <em>Beca Ibero</em> merit scholarship through a competitive mathematics problem-solving contest.</p>
        </div>
        <div class="edu-item fade-in">
          <h3>Universidad Nacional Autónoma de México (UNAM)</h3>
          <p class="edu-degree">B.A. in Political Science</p>
          <span class="edu-years">2022 – 2028 (expected)</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Technical Skills -->
  <section class="section skills-section">
    <div class="container">
      <h2 class="fade-in">Technical Skills</h2>
      <div class="skills-grid">
        <div class="skill-category fade-in">
          <h4>Programming</h4>
          <div class="skill-tags">
            <span>Python</span>
            <span>R</span>
            <span>C/C++</span>
            <span>SQL</span>
            <span>LaTeX</span>
            <span>Git</span>
          </div>
        </div>
        <div class="skill-category fade-in">
          <h4>Libraries & Tools</h4>
          <div class="skill-tags">
            <span>Pandas</span>
            <span>NumPy</span>
            <span>SciPy</span>
            <span>API Integration</span>
            <span>Web Scraping</span>
          </div>
        </div>
        <div class="skill-category fade-in">
          <h4>Data & Modeling</h4>
          <div class="skill-tags">
            <span>SQL/NoSQL</span>
            <span>Simulation</span>
            <span>Mathematical Modeling</span>
            <span>Process Mining</span>
          </div>
        </div>
        <div class="skill-category fade-in">
          <h4>Research</h4>
          <div class="skill-tags">
            <span>Scientific Writing</span>
            <span>Literature Review</span>
            <span>Quantitative Analysis</span>
            <span>Qualitative Analysis</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Languages & Awards -->
  <section class="section">
    <div class="container">
      <div class="bottom-grid">
        <div class="fade-in">
          <h2>Languages</h2>
          <div class="lang-list">
            <div class="lang-item">
              <span class="lang-name">Spanish</span>
              <span class="lang-level">Native proficiency</span>
            </div>
            <div class="lang-item">
              <span class="lang-name">English</span>
              <span class="lang-level">C2 — Certified by IELTS</span>
            </div>
          </div>
        </div>
        <div class="fade-in">
          <h2>Awards</h2>
          <div class="award-item">
            <h4>Beca Ibero — Universidad Iberoamericana</h4>
            <span class="award-year">2022</span>
            <p>Merit-based scholarship awarded upon winning a competitive mathematics problem-solving contest.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 10rem 0 3rem;
    background: var(--surface);
  }

  .page-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin-bottom: 1rem;
  }

  .page-desc {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.7;
    max-width: 600px;
  }

  /* Timeline */
  .timeline {
    margin-top: 2rem;
    position: relative;
    padding-left: 2rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: rgba(255, 255, 255, 0.1);
  }

  .timeline-item {
    position: relative;
    margin-bottom: 2.5rem;
  }

  .timeline-marker {
    position: absolute;
    left: -2rem;
    top: 0.25rem;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--accent);
    transform: translateX(-5px);
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .timeline-header h3 {
    font-size: 1.15rem;
  }

  .timeline-date {
    color: var(--accent);
    font-size: 0.85rem;
    font-weight: 500;
  }

  .timeline-role {
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-style: italic;
    margin-bottom: 0.75rem;
  }

  .timeline-details {
    list-style: none;
    padding: 0;
  }

  .timeline-details li {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
    padding-left: 1rem;
    position: relative;
    margin-bottom: 0.5rem;
  }

  .timeline-details li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .completed-tag {
    background: rgba(200, 121, 65, 0.15);
    color: var(--accent);
    padding: 0.15em 0.5em;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    margin-left: 0.5rem;
  }

  /* Leadership */
  .leadership-section {
    background: var(--surface);
  }

  .leadership-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .leadership-card {
    background: var(--bg);
    padding: 2rem;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .leadership-date {
    color: var(--accent);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 1px;
  }

  .leadership-card h3 {
    font-size: 1.15rem;
    margin: 0.5rem 0 0.25rem;
  }

  .leadership-role {
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-style: italic;
    margin-bottom: 0.75rem;
  }

  .leadership-desc {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  /* Publications */
  .publications-list {
    margin-top: 2rem;
    position: relative;
    padding-left: 2rem;
  }

  .publications-list::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: rgba(255, 255, 255, 0.1);
  }

  .publication-item {
    position: relative;
    margin-bottom: 2.5rem;
  }

  .publication-item .timeline-marker {
    position: absolute;
    left: -2rem;
    top: 0.25rem;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--accent);
    transform: translateX(-5px);
  }

  /* Education */
  .education-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .edu-item {
    background: var(--surface);
    padding: 2rem;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .edu-item h3 {
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }

  .edu-degree {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .edu-years {
    color: var(--accent);
    font-size: 0.85rem;
    font-weight: 500;
    display: block;
    margin: 0.25rem 0 0.75rem;
  }

  .edu-note {
    color: var(--text-secondary);
    font-size: 0.85rem;
    line-height: 1.5;
  }

  /* Skills */
  .skills-section {
    background: var(--surface);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }

  .skill-category h4 {
    font-size: 0.9rem;
    margin-bottom: 1rem;
    color: var(--accent);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tags span {
    background: var(--bg);
    color: var(--text-secondary);
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    font-size: 0.85rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  /* Bottom Grid */
  .bottom-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }

  .lang-list {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .lang-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .lang-name {
    font-weight: 600;
  }

  .lang-level {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .award-item {
    margin-top: 1rem;
  }

  .award-item h4 {
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }

  .award-year {
    color: var(--accent);
    font-size: 0.85rem;
    font-weight: 500;
  }

  .award-item p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
    margin-top: 0.5rem;
  }

  @media (max-width: 768px) {
    .bottom-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .leadership-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
